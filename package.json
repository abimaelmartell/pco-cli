{
  "name": "pco-cli",
  "version": "0.1.0",
  "description": "Agent-friendly TypeScript CLI for the Planning Center API.",
  "type": "module",
  "bin": {
    "pco": "dist/cli.js",
    "pco-cli": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "keywords": [
    "planning-center",
    "planning-center-online",
    "pco",
    "cli",
    "api",
    "agents"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "undici": "^6.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
